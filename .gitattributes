# Exclude media/binary from archives
*.bin export-ignore
*.png export-ignore
*.jpg export-ignore
*.jpeg export-ignore
*.gif export-ignore
*.wav export-ignore
*.mp3 export-ignore
*.mp4 export-ignore

# Exclude build artifacts
dist/ export-ignore
build/ export-ignore
node_modules/ export-ignore

# Exclude secrets
.env export-ignore
.env.* export-ignore

# Git LFS: large model binaries only (NOT small JSON/tokenizer/txt — those stay normal Git
# for diffable PR review). Self-hosted models are served from /models/ (no HuggingFace at runtime).
frontend/public/models/**/*.onnx filter=lfs diff=lfs merge=lfs -text
frontend/public/models/**/*.bin  filter=lfs diff=lfs merge=lfs -text
