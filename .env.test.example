# Template for the ROOT test env. Copy to `.env.test` (gitignored) and fill with TEST-only values.
# DO NOT commit a real `.env.test`. Use only Stripe TEST keys + throwaway test accounts.
# Never put live or service-role secrets here.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_AUTH_MODE=real
VITE_USE_MOCK_AUTH=false
VITE_POSTHOG_KEY=phc_your_posthog_key
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=
ASSEMBLYAI_API_KEY=your-assemblyai-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRO_PRICE_ID=price_test_xxx
VITE_STRIPE_PRICE_ID=price_test_xxx
VITE_PORT=5173
VITE_TEST_MODE=true
VITE_SKIP_MSW=false
TEST_USER_EMAIL=test+user@example.com
TEST_USER_PASSWORD=replace-with-test-only-password
BASIC_TEST_EMAIL=test+basic@example.com
BASIC_TEST_PASSWORD=replace-with-test-only-password
