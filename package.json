{
  "name": "speaksharp",
  "private": true,
  "version": "1.5.1",
  "type": "module",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.29.1",
    "npm": "Please_use_pnpm_to_manage_dependencies_in_this_repo"
  },
  "packageManager": "pnpm@10.29.1",
  "scripts": {
    "// ============ Development ============": "",
    "setup": "node scripts/pnpm-only.mjs && pnpm install --frozen-lockfile",
    "generate-promo": "node scripts/pnpm-only.mjs && tsx scripts/tools/generate-promo.ts",
    "dev:init": "node scripts/pnpm-only.mjs && ./scripts/dev-init.sh",
    "dev": "node scripts/pnpm-only.mjs && cd frontend && pnpm vite --port 5173 --mode test --logLevel error",
    "// ============ Build ============": "",
    "prebuild": "pnpm validate-env",
    "validate-env": "node scripts/validate-env.mjs",
    "build": "node scripts/pnpm-only.mjs && cd frontend && pnpm vite build --mode production",
    "prebuild:test": "pnpm validate-env",
    "build:test": "node scripts/pnpm-only.mjs && rm -rf frontend/dist && cd frontend && pnpm vite build --mode test",
    "preview": "node scripts/pnpm-only.mjs && cd frontend && pnpm vite preview",
    "preview:test": "node scripts/pnpm-only.mjs && cd frontend && pnpm vite preview --mode test",
    "// ============ Quality ============": "",
    "lint": "node scripts/pnpm-only.mjs && eslint 'frontend/src/**/*.{js,jsx,ts,tsx}' 'tests/**/*.{js,jsx,ts,tsx}' 'backend/supabase/functions/**/*.ts' --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "node scripts/pnpm-only.mjs && eslint 'frontend/src/**/*.{js,jsx,ts,tsx}' 'tests/**/*.{js,jsx,ts,tsx}' --fix",
    "eslint-disable": "node scripts/pnpm-only.mjs && ./scripts/check-eslint-disable.sh",
    "typecheck": "node scripts/pnpm-only.mjs && cd frontend && pnpm tsc --noEmit",
    "quality-code": "pnpm lint && pnpm typecheck && pnpm eslint-disable",
    "// ============ Testing (Taxonomy: test:<level>:<env>[:<mode>]) ============": "",
    "test": "pnpm test:unit:local",
    "test:unit:local": "node scripts/pnpm-only.mjs && echo 'NOTE: Running Unit and Component Integration tests...' && cross-env CI=true FORCE_COLOR=1 vitest run --config frontend/vitest.config.mjs --coverage --pool=forks",
    "test:unit:local:watch": "node scripts/pnpm-only.mjs && echo 'NOTE: Running Unit and Component Integration tests...' && vitest --config frontend/vitest.config.mjs",
    "test:agent": "node scripts/pnpm-only.mjs && ./scripts/test-audit.sh agent",
    "test:backend": "echo 'Backend unit tests (Deno) require Supabase CLI or Deno installed. Skipping local check.'",
    "// E2E Mocked (test:e2e:mock:<mode>)": "",
    "pretest:e2e:mock": "echo '🔨 Building fresh test bundle...' && pnpm build:test",
    "test:e2e:mock": "pnpm test:e2e:mock:headless",
    "test:e2e:mock:headless": "node scripts/pnpm-only.mjs && playwright test",
    "test:e2e:mock:headed": "node scripts/pnpm-only.mjs && playwright test tests/e2e --ui",
    "test:e2e:mock:debug": "cross-env DEBUG=pw:api DOTENV_CONFIG_PATH=.env.test playwright test --headed --trace on --project=chromium",
    "// Integration (test:int:<env>)": "",
    "test:int:local": "node scripts/pnpm-only.mjs && cross-env VITE_USE_LIVE_DB=true playwright test tests/live/auth.live.spec.ts tests/live/upgrade.live.spec.ts tests/live/analytics-journey.live.spec.ts --config=playwright.live.config.ts",
    "// System (test:system:<env>:<mode>)": "",
    "test:system:local:headed": "cross-env VITE_USE_LIVE_DB=true REAL_WHISPER_TEST=true playwright test tests/live --config=playwright.live.config.ts",
    "// Deploy (test:deploy:<env>)": "",
    "test:deploy": "pnpm test:deploy:prod",
    "test:deploy:prod": "cross-env BASE_URL=https://speaksharp-public.vercel.app playwright test tests/canary --config=playwright.canary.config.ts",
    "test:deploy:local": "playwright test tests/canary --config=playwright.canary.config.ts",
    "// Soak (test:soak:<type>:<env>)": "",
    "pretest:soak": "npx kill-port 5173 || true",
    "test:soak:ui:cloud": "dotenv -e .env.development -- playwright test --config=playwright.soak.config.ts --project=chromium",
    "test:soak:api:cloud": "dotenv -e .env.development -- tsx tests/soak/backend-api-stress-test.ts",
    "test:soak:verify:local": "dotenv -e .env.development -- tsx tests/soak/verify-users.ts",
    "// CI Orchestration (ci:<intent>:<target>)": "",
    "ci:prepare": "node scripts/pnpm-only.mjs && ./scripts/test-audit.sh prepare",
    "ci:test": "node scripts/pnpm-only.mjs && ./scripts/test-audit.sh test",
    "ci:report": "./scripts/test-audit.sh report",
    "ci:full:local": "node scripts/pnpm-only.mjs && ./scripts/test-audit.sh ci-simulate",
    "clean": "./scripts/test-audit.sh clean",
    "clean:nuclear": "./scripts/test-audit.sh clean --nuclear",
    "ci:dispatch:deploy": "echo '🚀 Dispatching deploy smoke...' && gh workflow run canary.yml && echo '✅ Dispatched. Monitor: gh run list --limit 1'",
    "ci:dispatch:soak": "echo '🚀 Dispatching soak test...' && gh workflow run soak-test.yml && echo '✅ Dispatched. Monitor: gh run list --limit 1'",
    "ci:dispatch:soak:wait": "node scripts/trigger-soak.mjs --wait",
    "test:all:local": "node scripts/pnpm-only.mjs && ./scripts/test-audit.sh local",
    "test:health:local": "node scripts/pnpm-only.mjs && ./scripts/test-audit.sh health-check",
    "pw:install": "playwright install chromium --with-deps",
    "pw:install:all": "playwright install --with-deps",
    "// ============ Maintenance & Setup ============": "",
    "preflight": "node scripts/pnpm-only.mjs && ./scripts/preflight.sh",
    "env:stabilize": "node scripts/pnpm-only.mjs && ./scripts/env-stabilizer.sh",
    "git:pull-fix": "node scripts/pnpm-only.mjs && ./scripts/git-pull-fix.sh",
    "model:download": "node scripts/pnpm-only.mjs && ./scripts/download-whisper-model.sh",
    "metrics:update": "node scripts/pnpm-only.mjs && tsx scripts/update-prd-metrics.mjs",
    "benchmark:whisper": "node scripts/pnpm-only.mjs && tsx scripts/benchmark-whisper-ceiling.mts",
    "benchmark:assemblyai": "node scripts/pnpm-only.mjs && tsx scripts/benchmark-assemblyai-ceiling.mts",
    "// ============ Git Hooks ============": "",
    "prepare": "HUSKY=0 husky install",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@sentry/react": "^10.27.0",
    "@stripe/react-stripe-js": "^4.0.2",
    "@stripe/stripe-js": "^7.9.0",
    "@supabase/supabase-js": "^2.86.0",
    "@tanstack/react-query": "^5.90.5",
    "@xenova/transformers": "^2.17.2",
    "assemblyai": "^4.16.1",
    "clsx": "^2.1.1",
    "compromise": "^14.14.5",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.23.26",
    "jspdf": "^3.0.2",
    "jspdf-autotable": "^5.0.2",
    "kill-port": "^2.0.1",
    "posthog-js": "^1.298.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.5.0",
    "sonner": "^2.0.7",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "whisper-turbo": "^0.11.0",
    "whisper-webgpu": "^0.10.0",
    "zustand": "^5.0.9"
  },
  "optionalDependencies": {
    "sharp": "0.33.1"
  },
  "devDependencies": {
    "@esbuild/darwin-arm64": "^0.25.12",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.57.0",
    "@rollup/rollup-darwin-arm64": "^4.53.2",
    "@tailwindcss/oxide-darwin-arm64": "^4.1.17",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/eslint-plugin": "^1.5.0",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.22",
    "baseline-browser-mapping": "^2.9.15",
    "canvas": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.8",
    "dotenv": "^16.6.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^5.1.1",
    "eslint-plugin-react-refresh": "^0.4.8",
    "happy-dom": "^20.0.10",
    "husky": "^8.0.3",
    "jose": "^6.1.0",
    "jsdom": "^28.1.0",
    "lightningcss-darwin-arm64": "^1.30.2",
    "lint-staged": "^15.2.7",
    "lucide-react": "^0.543.0",
    "msw": "^2.11.2",
    "next-themes": "^0.4.6",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pino": "^9.9.5",
    "postcss": "^8.5.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.1.7",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.3"
  },
  "msw": {
    "workerDirectory": "frontend/public"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx}": [
      "bash -c \"tsc --noEmit\""
    ]
  },
  "pnpm": {
    "overrides": {
      "rimraf": "^5.0.0",
      "node-domexception": "^2.0.2",
      "glob": ">=10.5.0"
    },
    "patchedDependencies": {
      "whisper-turbo@0.11.0": "patches/whisper-turbo@0.11.0.patch"
    }
  }
}