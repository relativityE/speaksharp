{
	"name": "speaksharp-frontend",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"predev": "node -e \"require('fs').mkdirSync('public/whisper-turbo/worker', { recursive: true })\"",
		"dev": "node ../scripts/pnpm-only.mjs && vite",
		"prebuild": "node -e \"require('fs').mkdirSync('public/whisper-turbo/worker', { recursive: true })\"",
		"build": "node ../scripts/pnpm-only.mjs && pnpm tsc && vite build",
		"lint": "node ../scripts/pnpm-only.mjs && eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"preview": "node ../scripts/pnpm-only.mjs && vite preview",
		"test": "node ../scripts/pnpm-only.mjs && vitest run --config vitest.config.mjs",
		"test:watch": "node ../scripts/pnpm-only.mjs && vitest --config vitest.config.mjs"
	},
	"dependencies": {
		"@xenova/transformers": "^2.17.2",
		"embla-carousel-react": "^8.6.0",
		"file-saver": "^2.0.5",
		"lodash-es": "^4.17.23",
		"pdfjs-dist": "^5.4.624"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@types/file-saver": "^2.0.7",
		"@types/lodash-es": "^4.17.12",
		"@vitest/coverage-v8": "^4.1.0",
		"jsdom": "^28.1.0",
		"madge": "^8.0.0",
		"vite-plugin-static-copy": "^3.2.0"
	}
}