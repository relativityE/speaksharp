# Template for the FRONTEND test env. Copy to `frontend/.env.test` (gitignored) and fill TEST-only values.
# SUPABASE_SERVICE_ROLE_KEY grants full DB/RLS bypass: NEVER commit it — provide only from a CI secret
# or local untracked env. Use Stripe TEST keys + throwaway accounts only.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=service-role-key-from-ci-secret-only
VITE_POSTHOG_KEY=phc_your_posthog_key
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_SENTRY_DSN=
ASSEMBLYAI_API_KEY=your-assemblyai-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRO_PRICE_ID=price_test_xxx
VITE_STRIPE_PRICE_ID=price_test_xxx
VITE_PORT=5173
VITE_TEST_MODE=true
VITE_SKIP_MSW=false
TEST_USER_EMAIL=test+user@example.com
TEST_USER_PASSWORD=replace-with-test-only-password
E2E_PRO_EMAIL=test+pro@example.com
E2E_PRO_PASSWORD=replace-with-test-only-password
